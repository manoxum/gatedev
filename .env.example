# Copie este arquivo para .env e ajuste os valores para o seu host.
# O .env real contem segredos (ex: WIFI_PASSWORD) e nao vai para o git
# (veja .gitignore). Este .env.example e o unico que deve ser versionado.

# ---------------------------------------------------------------------------
# Hotspot Wi-Fi (servico "hotspot", ver hotspot/entrypoint.sh)
# ---------------------------------------------------------------------------

# Interface Wi-Fi fisica que vai virar o ponto de acesso.
# Obrigatoria. Descubra com `iw dev` ou `nmcli device status`.
WIFI_INTERFACE=wlp0s20f3

# Interface com saida para a internet, cujo trafego sera compartilhado
# com quem conectar no hotspot (ex: interface ethernet ou outra Wi-Fi).
# Obrigatoria.
INTERNET_INTERFACE=enp1s0

# Nome (SSID) da rede Wi-Fi criada pelo hotspot.
# Obrigatoria.
WIFI_SSID=xCosta

# Senha da rede Wi-Fi (WPA2), minimo 8 caracteres.
# Obrigatoria e sensivel: nunca commitar o valor real.
WIFI_PASSWORD=troque-esta-senha

# Codigo de pais/regiao regulatoria Wi-Fi (ISO 3166-1 alpha-2).
# Opcional, padrao "ST" se omitido.
WIFI_COUNTRY=ST

# Canal Wi-Fi. Aceita um numero fixo (ex: 6, 36) ou "auto" para o
# proprio hotspot escanear o ambiente e escolher o canal menos
# congestionado dentro da banda selecionada (WIFI_FREQ_BAND).
# Opcional, padrao "auto".
WIFI_CHANNEL=auto

# Lista customizada de canais candidatos avaliados quando WIFI_CHANNEL=auto,
# separados por virgula ou espaco (ex: "1,6,11" ou "36 40 44 48").
# Opcional. Se omitida, usa 1/6/11 em 2.4GHz ou 36/40/44/48/149/153/157/161
# em 5GHz, de acordo com a banda resolvida.
#WIFI_CHANNEL_CANDIDATES=1,6,11

# Banda de frequencia do hotspot: "2.4", "5" ou "auto".
# Em "auto": se WIFI_CHANNEL for um numero fixo, a banda e inferida do
# canal; caso contrario, o hotspot detecta as bandas suportadas pela
# placa (via `iw`) e prefere 5GHz quando disponivel, caindo para 2.4GHz
# quando nao for possivel detectar ou a placa nao suportar 5GHz.
# Opcional, padrao "auto".
WIFI_FREQ_BAND=auto

# Gateway/IP do hotspot na rede local criada para os clientes conectados
# (tambem usado pelo dns-provider como IP de resposta para os TLDs locais).
# Opcional, padrao 192.168.12.1.
HOTSPOT_GATEWAY=192.168.12.1

# Faixa CIDR correspondente ao HOTSPOT_GATEWAY. Informativo, usado como
# referencia para configuracao manual de firewall/roteamento no host;
# nenhum servico deste repositorio le esta variavel diretamente hoje.
HOTSPOT_CIDR=192.168.12.0/24

# ---------------------------------------------------------------------------
# Rede do host / Docker (referencia para firewall e roteamento manual)
# ---------------------------------------------------------------------------
# Este host usa bridges Docker em 10.90.0.0/16. Em uma instalacao Docker
# padrao, os valores tipicos seriam DOCKER_HOST_GATEWAY=172.17.0.1 e
# DOCKER_CONTAINER_CIDR=172.16.0.0/12. Ajuste conforme o `docker network
# inspect bridge` do seu host.

# IP do host enxergado a partir dos containers (gateway das bridges Docker).
# Usado pelo dns-provider para saber em qual IP tambem escutar DNS.
DOCKER_HOST_GATEWAY=10.90.0.1

# Faixa CIDR das bridges Docker deste host. Informativo/reservado para
# regras de firewall; nenhum servico le esta variavel diretamente hoje.
DOCKER_CONTAINER_CIDR=10.90.0.0/16

# Faixa CIDR padrao do Docker (172.16.0.0/12), para hosts que nao
# customizaram o daemon Docker. Informativo/reservado.
DOCKER_DEFAULT_CONTAINER_CIDR=172.16.0.0/12

# IP atual da interface fisica do host (ex: o IP da LAN/Wi-Fi do proprio
# computador). Permite tratar consultas emitidas pelo host, usando esse
# IP como origem, como trafego "local". Informativo/reservado; ajuste
# para o IP real da sua maquina.
HOST_SOURCE_CIDR=10.234.2.102/32

# ---------------------------------------------------------------------------
# DNS split-horizon (servico "dns-provider", ver coredns/)
# ---------------------------------------------------------------------------

# TLDs locais que o CoreDNS resolve para HOTSPOT_GATEWAY, separados por
# virgula ou espaco (ex: "local,test,example").
# Opcional, padrao "local,test,example".
DNS_LOCAL_TLDS=local,test,example

# Tempo maximo (segundos) que o entrypoint do CoreDNS espera pelos IPs
# obrigatorios (127.0.0.1, DOCKER_HOST_GATEWAY, HOTSPOT_GATEWAY) antes de
# desistir e falhar. Opcional, padrao 90.
#COREDNS_WAIT_TIMEOUT=90

# ---------------------------------------------------------------------------
# Geral
# ---------------------------------------------------------------------------

# Timezone usada pelos containers (nginx-ui, cert-proxy).
# Opcional, padrao "Africa/Sao_Tome".
TZ=Africa/Sao_Tome
