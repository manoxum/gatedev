# Copie este arquivo para .env.main e ajuste os valores para o seu host.
# .env local/legado pode conter segredos e nao vai para o git (veja
# .gitignore). Este .env.example e o template publico.

# ---------------------------------------------------------------------------
# Promote / Compose
# ---------------------------------------------------------------------------

PROJECT=bindnet
STAGE=main
VERSION=v0.1.0
DOCKERHUB=brainsoftstp

# Arquivo de env que os containers com env_file leem. O fluxo oficial
# via bin/promote usa .env.main por causa de promote.yml/current_stage.
BINDNET_ENV_FILE=.env.main

# ---------------------------------------------------------------------------
# Hotspot Wi-Fi (servico "hotspot", ver services/worker/hotspot/entrypoint.sh)
# ---------------------------------------------------------------------------
# Toda a configuracao operacional do hotspot fica no painel
# (Hotspot -> "Alterar configuracao"), nao neste arquivo de ambiente.

# ---------------------------------------------------------------------------
# Rede do host / Docker (referencia para firewall e roteamento manual)
# ---------------------------------------------------------------------------
# O dns-provider detecta automaticamente os gateways das bridges Docker
# existentes no host e abre a view container nesses IPs. Para conferir a
# rede do Bindnet, use `docker network inspect bindnet_proxy`.

# IP da interface fisica do host (ex: o IP da LAN/Wi-Fi do proprio
# computador) onde o dns-provider tambem abre um listener DNS, para
# receber consultas encaminhadas por outros servidores Bindnet da malha.
# Opcional: por padrao (vazio/ausente) o dns-provider AUTO-DETECTA os IPs
# de LAN reais do host - so defina manualmente como escape hatch avancado
# se a auto-deteccao escolher a interface errada (ex.: host com multiplas
# placas de rede).
#HOST_SOURCE_CIDR=

# ---------------------------------------------------------------------------
# DNS split-horizon (servico "dns-provider", ver services/worker/dns/)
# ---------------------------------------------------------------------------

# TLDs locais do Bindnet, separados por virgula ou espaco
# (ex: "local,test,example").
# Opcional, padrao "local,test,example".
DNS_LOCAL_TLDS=local,test,example

# Dominios/zonas do modo discover, separados por virgula ou espaco.
# Aceita TLDs/raizes amplas ou sufixos completos (ex: bnet, costa.bnet,
# *.costa.bnet). Sufixos completos com mais de um label (ex: costa.bnet)
# sao tratados como zona local deste no e anunciados aos peers; subdominios
# como app.costa.bnet resolvem localmente. Raizes amplas de um label (ex:
# bnet) delimitam uma malha compartilhada: nomes dentro dela so resolvem se
# forem locais via nginx-ui/rotas proprias ou aprendidos de outro Bindnet.
# Opcional; deixe vazio para desligar o discover mode.
DOMAINS=discover

# Como tratar vizinhos remotos anunciados por peers diretos:
# - auto: aprende rotas indiretas anunciadas pelo peer direto.
# - manual: aprende so rotas proprias do peer direto; vizinhos remotos
#   precisam ser adicionados explicitamente pelo painel.
# Opcional, padrao auto.
DISCOVER_REMOTE_ROUTES=auto

# Nome deste servidor na malha de descoberta - aparece como "dono" nas
# rotas que ele anuncia aos vizinhos e no painel de administracao.
# Use aspas quando tiver espacos; o Bindnet remove essas aspas ao ler.
# Opcional, padrao o hostname do container.
#DISCOVER_NODE_NAME="Servidor A"

# Porta HTTP onde o dns-provider expoe a tabela de rotas para os
# peers consultarem (GET /discover/routes). Como o dns-provider roda
# com network_mode: host, essa porta fica exposta em todas as
# interfaces do host, sem autenticacao propria - so deve ser alcancavel
# dentro da rede confiavel do operador.
# Opcional, padrao 8531.
#DISCOVER_PORT=8531

# Dominios de busca anunciados por DHCP aos clientes do hotspot. Por
# padrao acompanha DNS_LOCAL_TLDS. Ajuda clientes Ubuntu/systemd-resolved
# a rotear *.local/*.test/*.example para o DNS recebido pelo Wi-Fi.
#DNS_SEARCH_DOMAINS=local,test,example

# Tempo maximo (segundos) que o dns-provider espera pelos IPs obrigatorios
# antes de desistir e falhar. Opcional, padrao 90.
#COREDNS_WAIT_TIMEOUT=90

# ---------------------------------------------------------------------------
# Painel de gestao (services/frontend, services/backend, services/worker)
# ---------------------------------------------------------------------------

# Credenciais do administrador do painel web. No primeiro boot criam
# /data/admin.json; em boots seguintes, se ADMIN_USERNAME e
# ADMIN_PASSWORD estiverem definidos, atualizam o hash persistido e
# invalidam sessoes antigas quando mudarem. Se ambas ficarem vazias e o
# arquivo ja existir, o backend usa o administrador persistido.
# Obrigatorias para criar o primeiro administrador.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Porta em que o backend (API do painel) escuta.
# Opcional, padrao 8090.
#BACKEND_PORT=8090

# Porta administrativa direta do nginx-ui.
# Opcional, padrao 9080.
#NGINX_UI_PORT=9080

# Porta publicada pelo container do frontend (interface web do painel).
# Opcional, padrao 9090.
#FRONTEND_PORT=9090

# ---------------------------------------------------------------------------
# Banco de dados e armazenamento (postgres, mongo, minio, migration)
# ---------------------------------------------------------------------------

# Usuario/senha/nome do banco Postgres, usado pelo services/backend (dados
# de certificados) e pelo services/migration (aplica as migrations na
# primeira subida). Dentro da rede Docker usa o nome "postgres"; no host
# fica publicado em POSTGRES_PORT para manutencao local.
# Obrigatorias.
POSTGRES_USER=bindnet
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=bindnet

# Porta local publicada para o Postgres.
# Opcional, padrao 9054.
#POSTGRES_PORT=9054

# Usuario/senha/nome do banco Mongo, usado pelo services/backend para a
# trilha de auditoria do painel (login/logout, mudancas de config,
# emissao/revogacao de certificado, start/stop de hotspot/dns) - NAO
# guarda logs de containers, so eventos do painel.
# Obrigatorias.
MONGO_USER=bindnet
MONGO_PASSWORD=troque-esta-senha
MONGO_DB=bindnet

# Por quantos dias o trace bruto de debito de credito do hotspot
# (uma linha por ciclo de reconciliacao com credito habilitado, colecao
# Mongo hotspot_credit_debits) fica guardado antes de expirar sozinho
# (indice TTL, ver services/backend/hotspot_credit_trace.go). O total
# consolidado por sessao continua no Postgres mesmo depois de expirar
# (hotspot_device_sessions) - so o extrato bruto some.
# Opcional, padrao 180 (6 meses).
#HOTSPOT_CREDIT_TRACE_RETENTION_DAYS=180

# Usuario/senha root do MinIO. Provisionado no stack para uso futuro de
# armazenamento de arquivos - nenhum servico usa isso hoje.
# Obrigatorias (o container minio nao sobe sem elas).
MINIO_ROOT_USER=bindnet
MINIO_ROOT_PASSWORD=troque-esta-senha

# Senha do Redis, usado pelo dns-provider como cache (hostname -> IP de
# loopback) hidratado a partir do Postgres na inicializacao - nao e fonte
# de verdade, so acelera consultas repetidas.
# Obrigatoria (o container redis nao sobe sem ela).
REDIS_PASSWORD=troque-esta-senha

# Nome comum (CN) da autoridade certificadora local (services/backend,
# gestao de certificados) - aparece como "emissor" nos certificados
# emitidos pelo painel. So tem efeito na primeira vez que a CA e gerada
# (sem CA legada importavel e sem CA ja no Postgres) - depois disso,
# mudar isto nao altera a CA ja criada (so uma nova CA, gerada do zero,
# usaria o novo nome).
# Opcional, padrao "Bindnet Local Development CA".
CA_COMMON_NAME=Bindnet Local Trust CA

# Caminho da base OUI local usada como fallback quando o lookup externo
# de fabricante por MAC estiver indisponivel. A imagem do backend ja
# inclui uma copia publica da IEEE neste caminho; altere apenas se for
# montar/gerir outra base local compatível com oui.csv.
#BINDNET_OUI_DB_PATH=/usr/local/share/bindnet/oui.csv

# URL interna do nginx-ui, usada pelo services/backend so para carregar
# automaticamente (via API do nginx-ui) o certificado assim que ele e
# emitido pelo painel. Opcional, padrao "http://nginx-ui:9000" (nome do
# servico na rede Docker "proxy").
#NGINX_UI_URL=http://nginx-ui:9000

# Credenciais de um usuario do nginx-ui (criado na configuracao inicial
# dele, nao tem relacao com ADMIN_USERNAME/ADMIN_PASSWORD do painel), so
# usadas pelo services/backend para autenticar na API do nginx-ui e
# cadastrar o certificado la. Opcionais: se deixadas vazias, a emissao de
# certificado funciona normalmente, so nao carrega automaticamente no
# nginx-ui (o usuario pode importar manualmente).
#NGINX_UI_USERNAME=
#NGINX_UI_PASSWORD=

# ---------------------------------------------------------------------------
# Geral
# ---------------------------------------------------------------------------

# Timezone usada pelos containers (nginx-ui, postgres, mongo, minio).
# Opcional, padrao "Africa/Sao_Tome".
TZ=Africa/Sao_Tome
