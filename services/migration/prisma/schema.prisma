// Prisma so gera e aplica migrations (prisma migrate deploy) contra o
// Postgres do stack - o services/backend (Go) nunca usa o Prisma
// Client, so o driver Postgres puro (ver services/backend/db.go).
// Rodar `npx prisma generate` aqui e opcional/nao usado em producao;
// o unico artefato que importa e prisma/migrations/.

generator client {
  provider      = "prisma-client-js"
  // node:22-alpine usa musl + OpenSSL 3.x - sem isso o Prisma tenta
  // adivinhar a engine certa e falha silenciosamente em runtime (ver
  // Dockerfile: precisa tambem do pacote "openssl" instalado via apk).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// CA local usada pela gestao de certificados (services/backend/certificates.go).
// Singleton na pratica (no maximo uma linha) - garantido por
// loadOrImportCA, nao por constraint de banco.
//
// id usa dbgenerated("gen_random_uuid()") em vez de @default(uuid()):
// o services/backend (Go) insere linhas via SQL puro, nao via Prisma
// Client, entao o UUID precisa ser gerado pelo proprio Postgres
// (DEFAULT na coluna), nao por uma funcao do lado do client Prisma.
model Ca {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commonName     String   @map("common_name")
  organization   String
  serialNumber   String   @map("serial_number")
  certificatePem String   @map("certificate_pem")
  privateKeyPem  String   @map("private_key_pem")
  issuedAt       DateTime @map("issued_at") @db.Timestamptz
  expiresAt      DateTime @map("expires_at") @db.Timestamptz
  source         String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("ca")
}

// Certificados-folha emitidos pela CA acima, via
// POST /api/certificates no painel de gestao.
model Certificate {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain         String
  commonName     String    @map("common_name")
  dnsNames       String[]  @map("dns_names")
  ipAddresses    String[]  @map("ip_addresses")
  serialNumber   String    @unique @map("serial_number")
  certificatePem String    @map("certificate_pem")
  privateKeyPem  String    @map("private_key_pem")
  issuedAt       DateTime  @map("issued_at") @db.Timestamptz
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([domain])
  @@map("certificates")
}

// Aloca um IP de loopback (127.x.y.z) persistente e unico por hostname,
// usado pelo dns-provider (services/worker/dns) para resolver consultas
// *.local/*.test/*.example vindas do proprio host (127.0.0.1) - cada
// hostname sempre resolve para o mesmo IP entre reinicios. loopbackOffset
// vem de local_dns_records_offset_seq (comeca em 2; offset 1 = 127.0.0.1
// e reservado). dns-provider mantem um cache Redis hidratado a partir
// desta tabela na inicializacao - ver services/worker/dns/cache.go.
model LocalDnsRecord {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostname       String   @unique
  loopbackOffset Int      @unique @map("loopback_offset")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("local_dns_records")
}

// Tabela de rotas da malha de discover mode (roteamento por proximo
// salto), mantida pelo dns-provider (services/worker/dns/discover_db.go)
// a partir da troca periodica com os peers configurados no Postgres.
// "owner" e o DISCOVER_NODE_NAME do dono final do dominio; "nextHop" e
// o endereco do vizinho direto para onde este no deve encaminhar a
// consulta; "distance" e o numero de saltos ate o dono. Sem Redis: o
// caminho quente de resolucao DNS le de um
// snapshot em memoria, nao desta tabela - ver RULE.md.
model DiscoverRoute {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain           String   @unique
  owner            String
  ownerFingerprint String?  @map("owner_fingerprint")
  nextHop          String   @map("next_hop")
  distance         Int
  source           String
  state            String   @default("ok")
  lastSeenAt       DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("discover_routes")
}

// Identidade persistente deste servidor Bindnet. Criada pelo dns-provider na
// primeira inicializacao e preservada em Postgres enquanto o volume existir.
model DiscoverNodeIdentity {
  id          Int      @id @default(1)
  fingerprint String   @unique
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("discover_node_identity")
}

// Peers diretos efetivamente configurados para troca de rotas. Essa tabela
// substitui o uso de arquivo .env como fonte de estado, para que limpar
// volumes tambem limpe os peers adicionados pelo painel.
model DiscoverConfiguredPeer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  address     String   @unique
  nodeName    String?  @map("node_name")
  fingerprint String?
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("discover_configured_peers")
}

// Ultimos servidores Bindnet encontrados por busca manual no painel.
// Esta tabela e informativa: um servidor so participa da malha quando
// o operador o adiciona explicitamente como peer direto.
model DiscoverPeer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  address     String   @unique
  nodeName    String   @map("node_name")
  fingerprint String?
  domains     String[] @default([])
  source      String   @default("manual-scan")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("discover_peers")
}

// Configuracao operacional do hotspot preenchida pelo painel administrativo.
// Nao fica em .env.main/.env.example; o backend injeta estes valores no
// container hotspot/dns-provider via worker ao aplicar/iniciar.
model HotspotConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_config")
}

// Configuracao do dns-provider preenchida pelo painel administrativo
// (DNS_LOCAL_TLDS, DOMAINS, DISCOVER_NODE_NAME, DISCOVER_REMOTE_ROUTES).
// Nao fica em .env.main/.env.example: o dns-provider le esta tabela direto
// do Postgres quando inicia. DISCOVER_PORT continua env (porta de
// infraestrutura, nao configuracao de negocio).
model DnsConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("dns_config")
}

// Configuracao do proprio painel/backend (CA_COMMON_NAME,
// NGINX_UI_USERNAME, NGINX_UI_PASSWORD), editada em Configuracoes.
// NGINX_UI_URL continua env (endereco interno do container).
model PanelConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("panel_config")
}

// Historico de sucesso/falha por combinacao (placa Wi-Fi, modo, banda,
// canal) do hotspot (services/worker/hotspot/history.sh) - usado pra
// priorizar, na proxima subida, os candidatos que ja funcionaram antes
// em vez de sempre reavaliar do zero. "mode" distingue 'same-interface'
// (Wi-Fi para Wi-Fi, canal travado pela estacao) de
// 'different-interface' (canal escolhido livremente, ex. Ethernet para
// Wi-Fi).
model HotspotChannelHistory {
  id            BigInt    @id @default(autoincrement())
  wifiInterface String    @map("wifi_interface")
  mode          String
  band          String
  channel       Int
  successCount  Int       @default(0) @map("success_count")
  failureCount  Int       @default(0) @map("failure_count")
  lastResult    String?   @map("last_result")
  lastAttemptAt DateTime? @map("last_attempt_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([wifiInterface, mode, band, channel])
  @@map("hotspot_channel_history")
}

// MACs bloqueados manualmente pelo painel (tela "Clientes conectados"
// do hotspot). services/backend reaplica esta lista via
// "hostapd_cli deny_acl" (services/worker/controller/hotspot_acl.go)
// toda vez que o hotspot sobe, ja que a ACL do hostapd so existe na
// memoria do processo e nao sobrevive a um restart do container.
model HotspotBlockedDevice {
  macAddress String   @id @map("mac_address")
  note       String?
  // "deauth" (padrao, compativel com o comportamento anterior) derruba
  // o dispositivo do Wi-Fi via hostapd (deny_acl+deauthenticate);
  // "traffic" so bloqueia o trafego via iptables, dispositivo continua
  // associado - ver applyLiveBlockForMode em hotspot_blocklist.go.
  mode       String   @default("deauth")
  blockedAt  DateTime @default(now()) @map("blocked_at") @db.Timestamptz

  @@map("hotspot_blocked_devices")
}

// Cache de identificacao de dispositivo por MAC (fabricante via OUI +
// heuristica de tipo/SO a partir do hostname/fingerprint DHCP - ver
// services/backend/hotspot_devices.go). Evita repetir a consulta
// externa (api.macvendors.com) e o parsing do log DHCP a cada poll de
// 5s da tela de clientes.
model HotspotDeviceInfo {
  macAddress String   @id @map("mac_address")
  vendor     String?
  deviceName String?  @map("device_name")
  osName     String?  @map("os_name")
  confidence Int?
  alias      String?  @unique
  fetchedAt  DateTime @default(now()) @map("fetched_at") @db.Timestamptz

  // Preenchidos automaticamente (recordDeviceSeen) toda vez que o MAC
  // aparece na lista de clientes ao vivo - diferente de fetchedAt
  // (so muda quando identificado/editado manualmente). Alimentam a
  // listagem de "dispositivos ja conectados" (GET /hotspot/devices/known).
  firstSeenAt DateTime? @map("first_seen_at") @db.Timestamptz
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz

  // Perfil vinculado (services/backend/hotspot_profiles_apply.go) - sem
  // FK proposital (mesmo padrao das demais tabelas hotspot_device_*).
  // DEFAULT aponta pro perfil "Padrao" semeado pela migration, entao
  // todo dispositivo (novo ou ja existente) ja nasce vinculado a ele.
  profileId String? @map("profile_id") @db.Uuid

  @@map("hotspot_device_info")
}

// Tabela legada do antigo limite de trafego global do hotspot
// (singleton, id fixo "global") - a funcionalidade foi removida (limite
// hoje e sempre por dispositivo ou perfil selecionado, ver RULE.md),
// sem leitor/escritor Go daqui pra frente. Fica no banco por convencao
// (migrations deste repo nunca fazem DROP TABLE).
model HotspotGlobalLimits {
  id                         String   @id @default("global") @map("id")
  downloadRateValue          Int?     @map("download_rate_value")
  downloadRateUnit           String   @default("mbit") @map("download_rate_unit")
  uploadRateValue            Int?     @map("upload_rate_value")
  uploadRateUnit             String   @default("mbit") @map("upload_rate_unit")
  quotaBytes                 BigInt?  @map("quota_bytes")
  quotaUnit                  String   @default("gbyte") @map("quota_unit")
  quotaPeriod                String?  @map("quota_period")
  quotaThrottleDownloadValue Int?     @map("quota_throttle_download_value")
  quotaThrottleDownloadUnit  String   @default("mbit") @map("quota_throttle_download_unit")
  quotaThrottleUploadValue   Int?     @map("quota_throttle_upload_value")
  quotaThrottleUploadUnit    String   @default("mbit") @map("quota_throttle_upload_unit")
  updatedAt                  DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_global_limits")
}

// Limite de trafego por dispositivo (mesma chave natural mac_address
// de HotspotBlockedDevice/HotspotDeviceInfo). Ver hotspot_device_limits.go.
//
// limitType/daily·weekly·monthlyQuotaBytes sao o shape novo (tipo
// unico e mutuamente exclusivo - ver services/backend/hotspot_device_limits.go).
// quotaBytes/quotaPeriod/quotaThrottle* sao o shape antigo: ficam no
// banco por convencao (migrations deste repo nunca fazem DROP COLUMN,
// ver 20260713000000_hotspot_limit_type/migration.sql), mas nao tem
// mais leitor/escritor Go nenhum (o antigo limite global que ainda
// usava esse shape foi removido, ver HotspotGlobalLimits acima).
model HotspotDeviceLimits {
  macAddress                 String   @id @map("mac_address")
  // Float (double precision) e nao Int: a taxa aceita valor
  // fracionario (1.5MB/s, 17.5KB/s) - ver migration
  // 20260716000000_hotspot_rate_decimal.
  downloadRateValue          Float?   @map("download_rate_value")
  downloadRateUnit           String   @default("mbit") @map("download_rate_unit")
  uploadRateValue            Float?   @map("upload_rate_value")
  uploadRateUnit             String   @default("mbit") @map("upload_rate_unit")
  quotaBytes                 BigInt?  @map("quota_bytes")
  quotaPeriod                String?  @map("quota_period")
  quotaThrottleDownloadValue Int?     @map("quota_throttle_download_value")
  quotaThrottleDownloadUnit  String   @default("mbit") @map("quota_throttle_download_unit")
  quotaThrottleUploadValue   Int?     @map("quota_throttle_upload_value")
  quotaThrottleUploadUnit    String   @default("mbit") @map("quota_throttle_upload_unit")

  limitType         String  @default("unlimited") @map("limit_type")
  dailyQuotaBytes   BigInt? @map("daily_quota_bytes")
  dailyQuotaUnit    String  @default("gbyte") @map("daily_quota_unit")
  weeklyQuotaBytes  BigInt? @map("weekly_quota_bytes")
  weeklyQuotaUnit   String  @default("gbyte") @map("weekly_quota_unit")
  monthlyQuotaBytes BigInt? @map("monthly_quota_bytes")
  monthlyQuotaUnit  String  @default("gbyte") @map("monthly_quota_unit")

  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_device_limits")
}

// Acumulador de uso do periodo corrente por (dispositivo, tipo de
// periodo) - 1 linha por periodo efetivamente configurado (diario/
// semanal/mensal), criada de forma preguicosa, mesmo padrao de
// ensureDeviceCreditRow/ensureDeviceTrafficRow. "blocked" e bloqueio
// rigido (nao throttle) ao estourar o teto daquele periodo - ver
// services/backend/hotspot_device_quota_store.go.
model HotspotDeviceQuotaPeriod {
  id            BigInt   @id @default(autoincrement())
  macAddress    String   @map("mac_address")
  periodType    String   @map("period_type")
  downloadBytes BigInt   @default(0) @map("download_bytes")
  uploadBytes   BigInt   @default(0) @map("upload_bytes")
  periodStart   DateTime @default(now()) @map("period_start") @db.Timestamptz
  periodEnd     DateTime @default(now()) @map("period_end") @db.Timestamptz
  blocked       Boolean  @default(false)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([macAddress, periodType])
  @@map("hotspot_device_quota_periods")
}

// Acumulador de trafego agregado do hotspot inteiro (singleton).
// last_*_counter guarda a ultima leitura absoluta dos contadores do
// worker, usada para calcular o delta a cada ciclo de reconciliacao e
// alimentar o velocimetro/grafico geral (useGlobalStats/
// useGlobalSpeedHistory no frontend) - ver services/backend/hotspot_traffic.go
// e hotspot_quota.go. downloadBytes/uploadBytes/throttled sao do antigo
// limite/cota global (removido, ver RULE.md): ainda incrementados por
// compatibilidade com a coluna, mas sem leitor Go.
model HotspotGlobalTraffic {
  id                  String   @id @default("global") @map("id")
  periodStart         DateTime @default(now()) @map("period_start") @db.Timestamptz
  periodEnd           DateTime @default(now()) @map("period_end") @db.Timestamptz
  downloadBytes       BigInt   @default(0) @map("download_bytes")
  uploadBytes         BigInt   @default(0) @map("upload_bytes")
  lastDownloadCounter BigInt   @default(0) @map("last_download_counter")
  lastUploadCounter   BigInt   @default(0) @map("last_upload_counter")
  throttled           Boolean  @default(false)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_global_traffic")
}

// Acumulador de uso do periodo corrente por dispositivo, criado de
// forma preguicosa na 1a vez que o dispositivo precisa ser rastreado
// (nao depende de limite configurado - tambem alimenta a velocidade ao
// vivo da pagina de detalhe). fwmark e o classid HTB/marca iptables
// dedicados a este dispositivo, atribuidos por
// hotspot_device_fwmark_seq (nunca hash de MAC, evita colisao).
model HotspotDeviceTraffic {
  macAddress          String   @id @map("mac_address")
  fwmark              Int      @unique @default(dbgenerated("nextval('hotspot_device_fwmark_seq')"))
  periodStart         DateTime @default(now()) @map("period_start") @db.Timestamptz
  periodEnd           DateTime @default(now()) @map("period_end") @db.Timestamptz
  downloadBytes       BigInt   @default(0) @map("download_bytes")
  uploadBytes         BigInt   @default(0) @map("upload_bytes")
  lastDownloadCounter BigInt   @default(0) @map("last_download_counter")
  lastUploadCounter   BigInt   @default(0) @map("last_upload_counter")
  throttled           Boolean  @default(false)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_device_traffic")
}

// Credito/recarga por dispositivo (services/backend/hotspot_credit.go).
// blockedByCredit fica separado de HotspotBlockedDevice (bloqueio
// manual do admin) de proposito - os dois mecanismos de bloqueio nao
// devem se confundir. recharge_period null = so recarga manual.
// configured=true quando o admin configurou credito manualmente para
// esse MAC (override vence sobre o perfil); false quando a linha so
// existe porque ensureDeviceCreditRow criou de forma preguicosa - ver
// services/backend/hotspot_profiles_apply.go (syncDeviceCreditFromProfile).
model HotspotDeviceCredit {
  macAddress          String    @id @map("mac_address")
  enabled             Boolean   @default(false)
  balanceBytes        BigInt    @default(0) @map("balance_bytes")
  rechargeAmountBytes BigInt?   @map("recharge_amount_bytes")
  rechargePeriod      String?   @map("recharge_period")
  plafondBytes        BigInt?   @map("plafond_bytes")
  nextRechargeAt      DateTime? @map("next_recharge_at") @db.Timestamptz
  blockedByCredit     Boolean   @default(false) @map("blocked_by_credit")
  configured          Boolean   @default(false)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_device_credit")
}

// Historico/extrato de mutacoes de saldo de credito por dispositivo -
// recarga manual, recarga automatica e resgate de voucher. O debito de
// trafego (entryType "debit") deixou de ser gravado aqui a partir da
// sessao/trace em Mongo (ver HotspotDeviceSession abaixo e
// hotspot_credit_debits no Mongo) - linhas "debit" antigas permanecem
// so como historico. Sem relacao FK proposital (mesmo padrao das
// demais tabelas hotspot_device_*).
model HotspotDeviceCreditHistory {
  id                BigInt   @id @default(autoincrement())
  macAddress        String   @map("mac_address")
  entryType         String   @map("entry_type")
  amountBytes       BigInt   @map("amount_bytes")
  balanceAfterBytes BigInt   @map("balance_after_bytes")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([macAddress, createdAt])
  @@map("hotspot_device_credit_history")
}

// Ciclo conectado/desconectado de um dispositivo no hotspot (inicio,
// fim, consumo total) - nasce quando o MAC aparece na lista de
// clientes ao vivo e fecha quando some dela (ver
// services/backend/hotspot_sessions.go). totalBytes e incrementado a
// cada debito de credito gravado no Mongo (hotspot_credit_debits),
// funcionando como o total consolidado que sobrevive mesmo depois do
// TTL apagar o extrato bruto de lá.
model HotspotDeviceSession {
  id         BigInt    @id @default(autoincrement())
  macAddress String    @map("mac_address")
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt    DateTime? @map("ended_at") @db.Timestamptz
  totalBytes BigInt    @default(0) @map("total_bytes")
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@index([macAddress, startedAt])
  @@map("hotspot_device_sessions")
}

// Perfil de dispositivo (services/backend/hotspot_profiles.go) - bundle
// nomeado e reutilizavel de limites de trafego (mesmo shape de
// HotspotDeviceLimits) + politica de credito (subconjunto de
// HotspotDeviceCredit, so politica, nunca saldo/estado). Todo
// dispositivo novo (e todo dispositivo ja existente, via DEFAULT da
// coluna profile_id em HotspotDeviceInfo) comeca vinculado ao perfil
// "Padrao" (id fixo, isDefault=true, semeado pela migration).
model HotspotProfile {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String  @unique
  isDefault Boolean @default(false) @map("is_default")

  // Float (double precision) e nao Int: a taxa aceita valor
  // fracionario (1.5MB/s, 17.5KB/s) - ver migration
  // 20260716000000_hotspot_rate_decimal.
  downloadRateValue          Float?   @map("download_rate_value")
  downloadRateUnit           String   @default("mbit") @map("download_rate_unit")
  uploadRateValue            Float?   @map("upload_rate_value")
  uploadRateUnit             String   @default("mbit") @map("upload_rate_unit")
  quotaBytes                 BigInt?  @map("quota_bytes")
  quotaPeriod                String?  @map("quota_period")
  quotaThrottleDownloadValue Int?     @map("quota_throttle_download_value")
  quotaThrottleDownloadUnit  String   @default("mbit") @map("quota_throttle_download_unit")
  quotaThrottleUploadValue   Int?     @map("quota_throttle_upload_value")
  quotaThrottleUploadUnit    String   @default("mbit") @map("quota_throttle_upload_unit")

  creditEnabled             Boolean  @default(false) @map("credit_enabled")
  creditRechargeAmountBytes BigInt?  @map("credit_recharge_amount_bytes")
  creditRechargePeriod      String?  @map("credit_recharge_period")
  creditPlafondBytes        BigInt?  @map("credit_plafond_bytes")

  // Isolamento de clientes (hotspot_isolation.go): com o interruptor
  // geral CLIENT_ISOLATION ligado, decide se os clientes deste perfil
  // comunicam entre si. Default false (tudo bloqueado ate configurar).
  allowInternalCommunication Boolean @default(false) @map("allow_internal_communication")

  // Shape novo (ver comentario em HotspotDeviceLimits acima) - creditEnabled
  // acima fica no banco sem uso do Go novo: limitType e que decide se a
  // politica de credito (recharge/plafond, linhas acima) esta ativa.
  limitType         String  @default("unlimited") @map("limit_type")
  dailyQuotaBytes   BigInt? @map("daily_quota_bytes")
  dailyQuotaUnit    String  @default("gbyte") @map("daily_quota_unit")
  weeklyQuotaBytes  BigInt? @map("weekly_quota_bytes")
  weeklyQuotaUnit   String  @default("gbyte") @map("weekly_quota_unit")
  monthlyQuotaBytes BigInt? @map("monthly_quota_bytes")
  monthlyQuotaUnit  String  @default("gbyte") @map("monthly_quota_unit")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("hotspot_profiles")
}

// Regra de comunicacao entre clientes do hotspot
// (services/backend/internal/hotspot/hotspot_isolation.go). Refs
// polimorficas: sourceKind device (sourceRef = MAC normalizado) ou
// profile (sourceRef = UUID de HotspotProfile); targetKind aceita
// tambem 'any' (targetRef NULL). Sem @relation de proposito (mesmo
// idioma do resto do schema, so colunas simples); regras de um perfil
// apagado sao removidas pela aplicacao. direction 'to' = source pode
// iniciar trafego para target; 'both' = os dois podem iniciar.
model HotspotCommRule {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceKind String  @map("source_kind")
  sourceRef  String  @map("source_ref")
  targetKind String  @map("target_kind")
  targetRef  String? @map("target_ref")
  direction  String  @default("both")
  action     String
  enabled    Boolean @default(true)
  note       String?

  // Base do firewall por zonas (migration 20260721010000). zone: caminho
  // de tráfego ('clients'|'wan'|'local'). protocol: 'any'|'tcp'|'udp'|'icmp'.
  // dstPorts: lista de portas/intervalos de destino (null = qualquer).
  // dstHost: IP/CIDR de destino externo, só na zona 'wan' (null = qualquer).
  zone     String  @default("clients")
  protocol String  @default("any")
  dstPorts String? @map("dst_ports")
  dstHost  String? @map("dst_host")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@index([sourceKind, sourceRef])
  @@index([targetKind, targetRef])
  @@index([zone])
  @@map("hotspot_comm_rules")
}

// Lote de vouchers (services/backend/hotspot_vouchers.go) - agrupa os
// vouchers emitidos juntos numa mesma chamada para permitir listagem e
// impressao em lote. Nao ha relacao Prisma declarada com HotspotVoucher.batchId
// de proposito (o restante do schema tambem so usa colunas FK simples,
// sem @relation).
model HotspotVoucherBatch {
  id          String   @id
  amountBytes BigInt   @map("amount_bytes")
  amountUnit  String   @default("gbyte") @map("amount_unit")
  quantity    Int
  note        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("hotspot_voucher_batches")
}

// Voucher/cartao de recarga (services/backend/hotspot_vouchers.go) -
// emitido pelo admin com um valor fixo em bytes, resgatado uma unica
// vez pelo proprio dispositivo sem login (identificado pelo MAC de
// origem, ver services/backend/hotspot_portal.go). status distingue
// 'active' (ainda nao usado), 'redeemed' (ja resgatado - redeemedByMac/
// redeemedAt preenchidos) e 'revoked' (cancelado pelo admin antes do uso).
// batchId agrupa vouchers emitidos juntos (ver HotspotVoucherBatch).
model HotspotVoucher {
  code          String    @id
  batchId       String?   @map("batch_id")
  amountBytes   BigInt    @map("amount_bytes")
  status        String    @default("active")
  note          String?
  redeemedByMac String?   @map("redeemed_by_mac")
  redeemedAt    DateTime? @map("redeemed_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, createdAt])
  @@index([batchId])
  @@map("hotspot_vouchers")
}
